# ReqRadar V2 环境变量
# 复制此文件为 .env 并填入实际值
#
# 本地开发最小配置（仅需 SQLite，无需 PostgreSQL/Redis/MinIO）：
#   DATABASE_URL=sqlite+aiosqlite:///./reqradar_dev.db
#   JWT_SECRET=any-random-string-for-dev

# === 安全密钥（必填） ===
JWT_SECRET=change-me-to-a-random-256-bit-hex
INTERNAL_API_KEY=change-me-to-another-random-256-bit-hex
ENCRYPTION_KEY=change-me-to-a-third-random-256-bit-hex

# === 数据库 ===
# 本地开发：SQLite（无需安装 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./reqradar_dev.db
# 生产/集成测试：PostgreSQL
# DB_PASSWORD=devpassword
# DATABASE_URL=postgresql+asyncpg://reqradar:${DB_PASSWORD}@localhost:5432/reqradar

# === LLM 配置（运行测试时不需要） ===
# OPENAI_API_KEY=sk-your-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# === MinIO（Phase 3+ 才需要） ===
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# === Redis（Phase 3+ 才需要） ===
# REDIS_URL=redis://localhost:6379

# === 可选 ===
# LOG_LEVEL=INFO
# SENTRY_DSN=
