# ReqRadar environment variables
REQRADAR_SECRET_KEY=change-me-to-a-random-secret

# LLM configuration (optional, defaults to OpenAI gpt-4o-mini)
# OPENAI_API_KEY=sk-your-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding model configuration (C-03 规范: REQRADAR_ 前缀 + __ 分隔)
# REQRADAR_EMBEDDING__HF_ENDPOINT=https://hf-mirror.com
# REQRADAR_EMBEDDING__MODEL_REPO=onnx-community/all-MiniLM-L6-v2-ONNX
# REQRADAR_EMBEDDING__MODEL_CACHE=~/.cache/reqradar/embedding
# REQRADAR_EMBEDDING__PRECISION=fp16
