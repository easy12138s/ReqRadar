# ReqRadar V2 环境变量模板
# 复制为 .env 并修改敏感值

# === 安全密钥（生产环境必须更换） ===
JWT_SECRET=change-me-to-a-random-secret
INTERNAL_API_KEY=change-me-to-a-random-internal-key

# === 数据库 ===
POSTGRES_DB=reqradar
POSTGRES_USER=reqradar
POSTGRES_PASSWORD=reqradar_dev
DATABASE_URL=postgresql+asyncpg://reqradar:reqradar_dev@postgres:5432/reqradar

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === LLM API ===
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=MiniMax-M2.5
LLM_BASE_URL=https://api.minimax.chat/v1

# === 服务地址（Docker 内部网络） ===
AUTH_SERVICE_URL=http://auth-service:8001
COGNITIVE_RT_URL=http://cognitive-rt:8002
INDEX_SERVICE_URL=http://index-service:8003
OUTPUT_SERVICE_URL=http://output-service:8004
INTEGRATION_SERVICE_URL=http://integration-service:8005

# === ChromaDB ===
CHROMADB_URL=http://chromadb:8000

# === MCP ===
MCP_HOST=0.0.0.0
MCP_PORT=9000
MCP_PATH=/mcp

# === 日志 ===
LOG_LEVEL=INFO
