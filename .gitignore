# ReqRadar - Python project .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linting
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ReqRadar - 本地运行时数据
.reqradar/
.reqradar.yaml

# Generated reports (keep .gitkeep)
reports/*
!reports/.gitkeep

# PyPI config
.pypirc

# Embedding model cache
.cache/

# Database
*.db
*.db-journal
*.db-wal
*.db-shm

# Frontend build output
src/reqradar/web/static/

# Frontend Testing - Vitest & Testing Library
frontend/src/**/__tests__/
frontend/src/**/*.test.ts
frontend/src/**/*.test.tsx
frontend/src/**/*.spec.ts
frontend/src/**/*.spec.tsx
frontend/vitest.config.ts
frontend/.vitest-cache/

# Frontend Testing - Coverage Reports
frontend/coverage/
frontend/.coverage*

# Frontend Testing - Playwright E2E
frontend/e2e/
frontend/playwright.config.ts
frontend/playwright-report/
frontend/test-results/

# Frontend Testing - Test Infrastructure (optional: keep if you want to share)
# Uncomment the following line to also exclude test utils/mocks
# frontend/src/test/

# Root-level test scripts (contain env-specific config)
/test_e2e.py
/test_minimax_api.py

# Backend tests
tests/

# OpenCode config
opencode.json
.opencode/

# Docs (design specs, requirements, issues — managed separately)
docs/.superpowers/
docs/
.superpowers/
.worktrees/
